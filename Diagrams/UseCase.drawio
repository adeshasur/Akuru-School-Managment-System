        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam linetype polyline\n\n&#39; Main Classes\nclass User {\n  - String userID\n  - String username\n  - String password\n  - String email\n  + login()\n  + logout()\n  + updateProfile()\n}\n\nclass Student {\n  - String studentID\n  - String dob\n  - String address\n  - String parentContact\n  + viewMarks()\n  + markAttendance()\n  + submitAssignment()\n}\n\nclass Teacher {\n  - String teacherID\n  - String specialization\n  - double salary\n  + uploadNotes()\n  + addMarks()\n  + updateAttendance()\n}\n\nclass Admin {\n  - String adminID\n  + registerUser()\n  + manageClasses()\n  + generateSystemReports()\n}\n\nclass ClassRoom {\n  - String classID\n  - String className\n  - int grade\n  + addStudent()\n  + setTeacher()\n}\n\nclass Subject {\n  - String subjectCode\n  - String subjectName\n  + getSyllabus()\n}\n\nclass Exam {\n  - String examID\n  - String examType\n  - Date date\n  + calculateAverage()\n}\n\nclass Attendance {\n  - Date date\n  - boolean isPresent\n  + getDailyReport()\n}\n\nclass Library {\n  - String bookID\n  - String bookTitle\n  + issueBook()\n  + returnBook()\n}\n\n&#39; Relationships &amp; Inheritance\nUser &lt;|-- Student : \&quot;inherits\&quot;\nUser &lt;|-- Teacher : \&quot;inherits\&quot;\nUser &lt;|-- Admin : \&quot;inherits\&quot;\n\nAdmin \&quot;1\&quot; -- \&quot;many\&quot; User : \&quot;manages\&quot;\nTeacher \&quot;1\&quot; -- \&quot;many\&quot; ClassRoom : \&quot;assigned to\&quot;\nClassRoom \&quot;1\&quot; *-- \&quot;many\&quot; Student : \&quot;contains\&quot;\nClassRoom \&quot;many\&quot; o-- \&quot;many\&quot; Subject : \&quot;has\&quot;\nStudent \&quot;1\&quot; -- \&quot;many\&quot; Attendance : \&quot;has\&quot;\nExam \&quot;many\&quot; -- \&quot;1\&quot; Subject : \&quot;based on\&quot;\nStudent \&quot;many\&quot; -- \&quot;many\&quot; Library : \&quot;uses\&quot;\n\n@enduml&quot;,&#xa;  &quot;